<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Админ-панель — LatysTime</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Segoe UI',sans-serif; background:#0b0a0e; color:#f0e6d3; min-height:100vh; display:flex; justify-content:center; align-items:flex-start; padding:30px 20px; background-image:radial-gradient(circle at 30% 20%,#1f1033 0%,#0b0a0e 85%); }
        .admin-container { width:100%; max-width:800px; }
        .admin-box { background:rgba(18,14,28,0.95); border:1px solid rgba(255,165,0,0.2); border-radius:30px; padding:30px; box-shadow:0 30px 80px rgba(0,0,0,0.9); }
        .admin-header { display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid rgba(255,165,0,0.15); padding-bottom:12px; margin-bottom:20px; }
        .admin-header h2 { color:#ffcc80; font-size:24px; }
        .btn-back { color:#9575cd; text-decoration:none; font-size:14px; padding:6px 16px; border:1px solid #4a3f5e; border-radius:20px; transition:0.3s; }
        .btn-back:hover { border-color:#b388ff; color:#b388ff; }
        .admin-nav { display:flex; gap:8px; flex-wrap:wrap; justify-content:center; margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid rgba(255,165,0,0.1); }
        .admin-nav button { background:transparent; border:1px solid #4a3f5e; color:#9575cd; padding:6px 16px; border-radius:20px; font-size:13px; font-weight:600; cursor:pointer; transition:0.3s; }
        .admin-nav button:hover { border-color:#b388ff; color:#b388ff; }
        .admin-nav button.active { background:#b388ff; color:#0b0a0e; border-color:#b388ff; }
        .admin-section { display:none; }
        .admin-section.active { display:block; }
        .admin-section p { color:#9575cd; font-size:13px; text-align:center; margin-bottom:10px; }
        .admin-nick-input { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin:10px 0 16px; }
        .admin-nick-input input { flex:1; min-width:160px; padding:10px 16px; border-radius:50px; border:1px solid rgba(255,165,0,0.2); background:rgba(255,255,255,0.05); color:#fff; font-size:14px; outline:none; }
        .admin-nick-input input:focus { border-color:#b388ff; }
        .btn-give-free { background:#66bb6a; border:none; padding:10px 24px; border-radius:50px; font-size:14px; font-weight:700; color:#0b0a0e; cursor:pointer; transition:0.3s; text-transform:uppercase; }
        .btn-give-free:hover { transform:scale(1.05); }
        .admin-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:10px; }
        .admin-grid .product-card { background:rgba(255,255,255,0.02); border:1px solid rgba(255,165,0,0.08); border-radius:16px; padding:12px 10px; text-align:center; transition:0.3s; cursor:pointer; }
        .admin-grid .product-card:hover { transform:translateY(-3px); border-color:#66bb6a; }
        .admin-grid .product-card .name { font-size:15px; font-weight:700; color:#ffe0b2; }
        .admin-grid .product-card .price { font-size:12px; color:#4a3f5e; margin-top:2px; text-decoration:line-through; }
        .admin-grid .product-card .free { color:#66bb6a; font-weight:700; font-size:12px; margin-top:2px; }
        .stats-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:10px; margin-top:10px; }
        .stats-grid .stat-card { background:rgba(255,255,255,0.02); border:1px solid rgba(255,165,0,0.08); border-radius:16px; padding:14px 12px; text-align:center; }
        .stats-grid .stat-card .number { font-size:24px; font-weight:800; color:#ffcc80; }
        .stats-grid .stat-card .label { font-size:11px; color:#9575cd; margin-top:2px; }
        .transaction-item { background:rgba(255,255,255,0.02); border:1px solid rgba(255,165,0,0.06); border-radius:12px; padding:12px 16px; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; }
        .transaction-item .info .nick { font-weight:700; color:#ffe0b2; }
        .transaction-item .info .product { color:#b388ff; font-size:13px; }
        .transaction-item .info .price { color:#ffab40; font-size:13px; }
        .transaction-item .info .date { color:#4a3f5e; font-size:11px; }
        .transaction-item .status { padding:3px 12px; border-radius:12px; font-size:11px; font-weight:700; text-transform:uppercase; }
        .transaction-item .status.pending { background:rgba(255,165,0,0.15); color:#ffab40; }
        .transaction-item .status.done { background:rgba(102,187,106,0.15); color:#66bb6a; }
        .transaction-item .status.free { background:rgba(179,136,255,0.15); color:#b388ff; }
        .empty-orders { color:#4a3f5e; text-align:center; padding:20px; }
        #transactionsList { max-height:300px; overflow-y:auto; margin-top:5px; }
        #transactionsList::-webkit-scrollbar { width:4px; }
        #transactionsList::-webkit-scrollbar-track { background:rgba(255,255,255,0.02); border-radius:10px; }
        #transactionsList::-webkit-scrollbar-thumb { background:#b388ff; border-radius:10px; }
        h3 { color:#ffcc80; font-size:18px; text-align:center; margin:15px 0 8px; }
        @media(max-width:600px){ .admin-box { padding:20px 16px; } .admin-grid { grid-template-columns:1fr 1fr; } }
    </style>
</head>
<body>

    <div class="admin-container">
        <div class="admin-box">
            <div class="admin-header">
                <h2>🔐 Админ-панель</h2>
                <a href="index.html" class="btn-back">🏠 На сайт</a>
            </div>

            <div class="admin-nav">
                <button class="active" onclick="switchSection('give')">🎁 Выдача</button>
                <button onclick="switchSection('stats')">📊 Статистика</button>
                <button onclick="switchSection('server')">🖥️ Сервер</button>
            </div>

            <!-- ===== РАЗДЕЛ: ВЫДАЧА ===== -->
            <div class="admin-section active" id="section-give">
                <p>Выберите товар, введите ник и нажмите "Выдать"</p>
                <div class="admin-nick-input">
                    <input type="text" id="adminNickname" placeholder="Введите ник игрока" maxlength="16" />
                    <button class="btn-give-free" onclick="adminGiveFree()">✅ Выдать</button>
                </div>
                <div class="admin-grid" id="adminShopGrid"></div>
            </div>

            <!-- ===== РАЗДЕЛ: СТАТИСТИКА ===== -->
            <div class="admin-section" id="section-stats">
                <p>Общая информация о работе сайта</p>
                <div class="stats-grid">
                    <div class="stat-card"><div class="number" id="statTotalOrders">0</div><div class="label">Всего заказов</div></div>
                    <div class="stat-card"><div class="number" id="statPendingOrders">0</div><div class="label">Ожидают выдачи</div></div>
                    <div class="stat-card"><div class="number" id="statDoneOrders">0</div><div class="label">Выдано</div></div>
                    <div class="stat-card"><div class="number" id="statTotalRevenue">0</div><div class="label">Выручка (₽)</div></div>
                </div>
                <h3>📋 История транзакций</h3>
                <div id="transactionsList">
                    <div class="empty-orders">Транзакций пока нет</div>
                </div>
            </div>

            <!-- ===== РАЗДЕЛ: СЕРВЕР ===== -->
            <div class="admin-section" id="section-server">
                <p>Информация о Minecraft-сервере</p>
                <div class="stats-grid">
                    <div class="stat-card"><div class="number" id="serverOnline">0</div><div class="label">Игроков онлайн</div></div>
                    <div class="stat-card"><div class="number" id="serverMaxPlayers">0</div><div class="label">Максимум</div></div>
                    <div class="stat-card"><div class="number" id="serverStatus">⏳</div><div class="label">Статус</div></div>
                    <div class="stat-card"><div class="number" id="serverVersion">—</div><div class="label">Версия</div></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let adminSelectedProduct = null;
        let orders = JSON.parse(localStorage.getItem('latys_orders') || '[]');

        const allProducts = [
            { name: 'Элита', price: 250 },
            { name: 'Титан', price: 300 },
            { name: 'Принц', price: 600 },
            { name: 'Князь', price: 900 },
            { name: 'Герцог', price: 1700 },
            { name: 'Кейс с токенами', price: 15 },
            { name: 'Монетный ключ', price: 10 },
            { name: 'Размут', price: 80 },
            { name: 'Разбан', price: 150 },
            { name: 'Восстановление прав', price: 400 }
        ];

        function saveOrders() { localStorage.setItem('latys_orders', JSON.stringify(orders)); }

        function renderAdminShop() {
            const container = document.getElementById('adminShopGrid');
            if (!container) return;
            container.innerHTML = '';
            allProducts.forEach(item => {
                const card = document.createElement('div');
                card.className = 'product-card';
                card.innerHTML = `
                    <div class="name">${item.name}</div>
                    <div class="price">${item.price} ₽</div>
                    <div class="free">🎁 БЕСПЛАТНО</div>
                `;
                card.onclick = () => {
                    adminSelectedProduct = item;
                    document.getElementById('adminNickname').focus();
                    document.querySelectorAll('#adminShopGrid .product-card').forEach(c => c.style.borderColor = 'rgba(255,165,0,0.08)');
                    card.style.borderColor = '#66bb6a';
                };
                container.appendChild(card);
            });
        }

        function switchSection(section) {
            document.querySelectorAll('.admin-section').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.admin-nav button').forEach(el => el.classList.remove('active'));
            document.getElementById('section-' + section).classList.add('active');
            document.querySelector(`.admin-nav button[onclick="switchSection('${section}')"]`).classList.add('active');
            if (section === 'stats') updateStats();
            if (section === 'server') updateServer();
        }

        function adminGiveFree() {
            const nickname = document.getElementById('adminNickname').value.trim();
            if (!nickname) { alert('⚠️ Введите ник игрока!'); return; }
            if (nickname.length < 3 || nickname.length > 16) { alert('⚠️ Ник от 3 до 16 символов'); return; }
            if (!adminSelectedProduct) { alert('⚠️ Выберите товар (кликните по карточке)'); return; }

            const order = {
                id: Date.now(),
                nickname: nickname,
                product: adminSelectedProduct.name,
                price: 0,
                date: new Date().toISOString(),
                status: 'free'
            };
            orders.push(order);
            saveOrders();

            alert(`✅ Бесплатная выдача!\nИгрок: ${nickname}\nТовар: ${adminSelectedProduct.name}`);
            document.getElementById('adminNickname').value = '';
            adminSelectedProduct = null;
            document.querySelectorAll('#adminShopGrid .product-card').forEach(c => c.style.borderColor = 'rgba(255,165,0,0.08)');
            updateStats();
        }

        function updateStats() {
            const total = orders.length;
            const pending = orders.filter(o => o.status === 'pending').length;
            const done = orders.filter(o => o.status === 'done' || o.status === 'free').length;
            const revenue = orders.filter(o => o.status === 'done').reduce((sum, o) => sum
